rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ===== เอกสาร PDF/Word/PPT =====
    match /documents/{catId}/{fileName} {
      // ทุกคนดาวน์โหลดได้
      allow read: if true;

      // อัปโหลดได้เฉพาะ admin ที่ approved แล้ว
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024
                   && request.resource.contentType.matches('application/(pdf|msword|vnd\\..*|octet-stream)');

      // ลบได้เฉพาะ admin ที่ approved แล้ว
      allow delete: if request.auth != null;
    }

  }
}
