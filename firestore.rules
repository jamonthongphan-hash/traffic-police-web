rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== ผู้เข้าชม: นับ counter ได้ =====
    match /visitors/counter {
      allow read:   if true;
      allow write:  if true;  // increment only — ไม่มีข้อมูลส่วนตัว
    }

    // ===== Users =====
    match /users/{uid} {
      // สมัครสมาชิก: สร้าง record ตัวเองได้
      allow create: if request.auth != null && request.auth.uid == uid;

      // อ่านข้อมูลตัวเอง หรือ super_admin อ่านได้ทุกคน
      allow read:   if request.auth != null &&
                      (request.auth.uid == uid || isSuperAdmin());

      // แก้ไขได้เฉพาะ super_admin
      allow update: if isSuperAdmin();

      // ลบได้เฉพาะ super_admin
      allow delete: if isSuperAdmin();
    }

    // ===== Site Data (categories) =====
    match /siteData/{docId} {
      allow read:  if true;   // ทุกคนอ่านได้
      allow write: if request.auth != null &&
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approved == true;
    }

    // ===== Activity Logs =====
    match /activityLogs/{logId} {
      // admin ที่ approved เขียนได้
      allow create: if request.auth != null &&
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approved == true;
      // อ่านได้เฉพาะ super_admin
      allow read: if isSuperAdmin();
    }

    // ===== Helper Functions =====
    function isSuperAdmin() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin';
    }

  }
}
